export class RedChaosEmerald {
  constructor(x, y) {
    this.x = x;
    this.y = y;

    this.baseY = y;
    this.floatTimer = 0;

    this.angle = 0;
    this.spinSpeed = 0.07;

    this.collected = false;

    this.hoverStrength = 12;

    // 🔥 “danger zone” mechanic (simple guard logic)
    this.guardRadius = 90;
    this.isGuarded = true;
  }

  update(player) {
    if (this.collected) return;

    this.floatTimer += 0.08;
    this.angle += this.spinSpeed;

    this.y = this.baseY + Math.sin(this.floatTimer) * this.hoverStrength;

    const dx = player.x - this.x;
    const dy = player.y - this.y;

    const dist = Math.sqrt(dx * dx + dy * dy);

    // 🧠 Guard mechanic: too close = knockback (simple obstacle feel)
    if (this.isGuarded && dist < this.guardRadius) {
      this.knockbackPlayer(player, dx, dy);
    }

    // 💎 collect condition (still normal pickup range)
    if (dist < 42) {
      this.collect();
    }
  }

  knockbackPlayer(player, dx, dy) {
    const length = Math.sqrt(dx * dx + dy * dy);

    const nx = dx / length;
    const ny = dy / length;

    // push player away (feels like “energy field” or Eggman defense)
    player.vx += nx * 6;
    player.vy += ny * 3;

    console.log("⚠️ Red Emerald guard repels player!");
  }

  collect() {
    this.collected = true;

    window.gameProgress = window.gameProgress || {
      emeralds: {
        blue: false,
        yellow: false,
        green: false,
        red: false,
        white: false,
        cyan: false,
        purple: false
      }
    };

    window.gameProgress.emeralds.red = true;

    console.log("❤️ Red Chaos Emerald collected!");
  }

  draw(ctx) {
    if (this.collected) return;

    ctx.save();

    // intense glow (more powerful than others)
    ctx.shadowColor = "red";
    ctx.shadowBlur = 35;

    ctx.translate(this.x, this.y);
    ctx.rotate(this.angle);

    ctx.fillStyle = "red";

    ctx.beginPath();
    ctx.moveTo(0, -16);
    ctx.lineTo(14, 0);
    ctx.lineTo(0, 16);
    ctx.lineTo(-14, 0);
    ctx.closePath();
    ctx.fill();

    ctx.restore();
  }
} 
import { RedChaosEmerald } from "./emerald_red.js";

const redEmerald = new RedChaosEmerald(1400, 240);

// update
function update(player) {
  redEmerald.update(player);
  player.update(input);
}

// draw
function draw(ctx, sprites) {
  redEmerald.draw(ctx);
  player.draw(ctx, sprites);
} 
