export class ChaosEmerald {
  constructor(x, y, color = "blue") {
    this.x = x;
    this.y = y;

    this.color = color;

    this.collected = false;

    // floating animation
    this.baseY = y;
    this.floatTimer = 0;

    // spin animation
    this.angle = 0;
    this.spinSpeed = 0.05;

    this.radius = 16;
  }

  update(player) {
    if (this.collected) return;

    this.floatTimer += 0.05;
    this.angle += this.spinSpeed;

    // floating up/down
    this.y = this.baseY + Math.sin(this.floatTimer) * 6;

    // collision check (simple circle distance)
    const dx = player.x - this.x;
    const dy = player.y - this.y;

    const dist = Math.sqrt(dx * dx + dy * dy);

    if (dist < 40) {
      this.collect();
    }
  }

  collect() {
    this.collected = true;

    // Save progress globally
    window.gameProgress = window.gameProgress || {
      emeralds: {
        blue: false,
        green: false,
        red: false,
        yellow: false,
        white: false,
        cyan: false,
        purple: false
      }
    };

    window.gameProgress.emeralds.blue = true;

    console.log("💎 Blue Chaos Emerald collected!");
  }

  draw(ctx, sprite) {
    if (this.collected) return;

    ctx.save();

    // glow effect
    ctx.shadowColor = "cyan";
    ctx.shadowBlur = 20;

    ctx.translate(this.x, this.y);
    ctx.rotate(this.angle);

    // fallback if no sprite
    if (sprite) {
      ctx.drawImage(sprite, -16, -16, 32, 32);
    } else {
      // simple placeholder diamond
      ctx.fillStyle = "deepskyblue";
      ctx.beginPath();
      ctx.moveTo(0, -16);
      ctx.lineTo(14, 0);
      ctx.lineTo(0, 16);
      ctx.lineTo(-14, 0);
      ctx.closePath();
      ctx.fill();
    }

    ctx.restore();
  }
} 
import { ChaosEmerald } from "./emerald.js";

const blueEmerald = new ChaosEmerald(400, 250);

// in your update loop:
function update(player) {
  blueEmerald.update(player);

  player.update(input);
