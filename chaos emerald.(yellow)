export class YellowChaosEmerald {
  constructor(x, y) {
    this.x = x;
    this.y = y;

    this.baseY = y;
    this.floatTimer = 0;

    this.angle = 0;
    this.spinSpeed = 0.06;

    this.collected = false;
    this.radius = 16;

    // slightly more “active” than blue (tiny hover variation)
    this.hoverStrength = 8;
  }

  update(player) {
    if (this.collected) return;

    this.floatTimer += 0.06;
    this.angle += this.spinSpeed;

    // stronger floating motion (makes it feel more “important”)
    this.y = this.baseY + Math.sin(this.floatTimer) * this.hoverStrength;

    const dx = player.x - this.x;
    const dy = player.y - this.y;

    const dist = Math.sqrt(dx * dx + dy * dy);

    if (dist < 40) {
      this.collect();
    }
  }

  collect() {
    this.collected = true;

    window.gameProgress = window.gameProgress || {
      emeralds: {
        blue: true,
        yellow: true,
        green: false,
        red: false,
        white: false,
        cyan: false,
        purple: false
      }
    };

    window.gameProgress.emeralds.yellow = true;

    console.log("💛 Yellow Chaos Emerald collected!");
  }

  draw(ctx) {
    if (this.collected) return;

    ctx.save();

    // yellow glow
    ctx.shadowColor = "gold";
    ctx.shadowBlur = 25;

    ctx.translate(this.x, this.y);
    ctx.rotate(this.angle);

    // fallback shape
    ctx.fillStyle = "gold";
    ctx.beginPath();
    ctx.moveTo(0, -16);
    ctx.lineTo(14, 0);
    ctx.lineTo(0, 16);
    ctx.lineTo(-14, 0);
    ctx.closePath();
    ctx.fill();

    ctx.restore();
  }
} 
import { YellowChaosEmerald } from "./emerald_yellow.js";

const yellowEmerald = new YellowChaosEmerald(700, 260);

// update loop
function update(player) {
  yellowEmerald.update(player);
  player.update(input);
}

// draw loop
function draw(ctx, sprites) {
  yellowEmerald.draw(ctx);
  player.draw(ctx, sprites);
} 
